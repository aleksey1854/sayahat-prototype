# ── База данных (PostgreSQL: Vercel Postgres / Neon) ──────────────────────────
# DATABASE_URL — пул для приложения (в хосте обычно есть "-pooler").
# DATABASE_URL_UNPOOLED — прямое подключение для миграций.
# Если провайдер даёт одну строку — впиши её в обе переменные.
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Полный адрес сайта (для sitemap, канониклов, микроразметки).
SITE_URL="http://localhost:3000"

# ── Хранилище фото (Vercel Blob) ─────────────────────────────────────────────
# На Vercel подставится автоматически при подключении Blob.
# Локально можно оставить пустым — фото будут писаться на диск в папку uploads/.
BLOB_READ_WRITE_TOKEN=""

# ── Счётчики (по желанию) ─────────────────────────────────────────────────────
NEXT_PUBLIC_YM_ID=""
NEXT_PUBLIC_GA_ID=""

# ── Секрет сессий кабинетов (обязательно свой на проде) ───────────────────────
# Сгенерировать: openssl rand -base64 32
SESSION_SECRET="dev-only-secret-change-me-in-production-000"

# ── Подтверждение прав в поисковиках (можно позже) ────────────────────────────
GOOGLE_SITE_VERIFICATION=""
YANDEX_VERIFICATION=""
